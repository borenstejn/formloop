# formloop environment variables
#
# LOCAL MODE (default): no env vars needed!
# Just run `npx formloop` — data is stored in memory, no auth required.
#
# HOSTED MODE: set the variables below for persistent Redis storage + auth.

# --- Hosted mode only ---

# API authentication secret (header: X-Webhook-Secret)
# If unset, all API endpoints are open (fine for localhost).
# WEBHOOK_SECRET=change-me-to-a-long-random-string

# Upstash Redis (via Vercel Marketplace or direct)
# If unset, formloop uses in-memory storage (data lost on restart).
# KV_REST_API_URL=https://xxx.upstash.io
# KV_REST_API_TOKEN=xxx
